{
    "version": 1,
    "target_mcu": {
        "name": "ATtiny202"
    },
    "test": {
        "name": "PA2 PA3 tracking",
        "description": "PA3 should always follow PA2."
    },
    "expected_events": [
        {
            "pin": "ATtiny202.PA2",
            "type": "RISE"
        },
        {
            "pin": "ATtiny202.PA3",
            "type": "RISE"
        },
        {
            "pin": "ATtiny202.PA2",
            "type": "FALL"
        },
        {
            "pin": "ATtiny202.PA3",
            "type": "FALL"
        }
    ]
}